{
  "name": "stella-ui",
  "private": true,
  "version": "0.0.0",
  "description": "Stella UI – scalable design system for web",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @stella-ds/docs storybook",
    "storybook": "pnpm --filter @stella-ds/docs storybook",
    "build-storybook": "pnpm --filter @stella-ds/docs build-storybook",
    "typecheck": "pnpm -r typecheck",
    "lint": "npx eslint packages/react/src apps/docs/src apps/site/src apps/site/app",
    "lint:fix": "npx eslint packages/react/src apps/docs/src apps/site/src apps/site/app --fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-jsx-a11y>eslint": "10",
        "eslint-plugin-react>eslint": "10",
        "eslint-plugin-react-hooks>eslint": "10"
      }
    }
  },
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": "10.33.2"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
