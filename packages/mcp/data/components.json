    "example": "// Wrap app once:\n<ToastProvider><ToastViewport /></ToastProvider>\n\n// Then render:\n<Toast open={open} onOpenChange={setOpen} variant=\"success\">\n  <ToastTitle>Saved!</ToastTitle>\n  <ToastDescription>Your file has been saved.</ToastDescription>\n  <ToastClose />\n</Toast>"
  },
  {
    "name": "Tooltip",
    "slug": "tooltip",
    "description": "Hover tooltip, built on Radix UI",
    "category": "overlay",
    "imports": ["TooltipProvider", "Tooltip", "TooltipTrigger", "TooltipContent"],
    "props": [
      {"name": "side", "type": "'top' | 'right' | 'bottom' | 'left'", "default": "'top'", "description": "TooltipContent: preferred side"},
      {"name": "sideOffset", "type": "number", "default": "6", "description": "TooltipContent: distance from trigger"}
