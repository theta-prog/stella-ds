  {
    "name": "Header",
    "slug": "header",
    "description": "Flexible site header with sticky, blur, and mobile nav support",
    "category": "layout",
    "imports": ["Header", "HeaderBrand", "HeaderNav", "HeaderActions"],
    "props": [
      {"name": "sticky", "type": "boolean", "default": "false", "description": "Sticks to viewport top"},
      {"name": "blur", "type": "boolean", "default": "true", "description": "Backdrop blur when sticky"},
