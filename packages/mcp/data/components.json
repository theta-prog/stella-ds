    ],
    "example": "<Header sticky>\n  <HeaderBrand>Stella UI</HeaderBrand>\n  <HeaderNav>\n    <a href=\"/\">Home</a>\n    <a href=\"/docs\">Docs</a>\n  </HeaderNav>\n  <HeaderActions><Button size=\"sm\">Get Started</Button></HeaderActions>\n</Header>"
  },
  {
    "name": "Heading",
    "slug": "heading",
    "description": "Semantic h1–h6 with size, weight, and alignment control",
    "category": "typography",
    "imports": ["Heading"],
    "props": [
      {"name": "level", "type": "1 | 2 | 3 | 4 | 5 | 6", "default": "2", "description": "Semantic heading level"},
      {"name": "size", "type": "'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl'", "default": "maps from level", "description": "Visual size override"},
      {"name": "weight", "type": "'normal' | 'medium' | 'semibold' | 'bold'", "default": "'bold'", "description": "Font weight"},
      {"name": "align", "type": "'left' | 'center' | 'right'", "default": "'left'", "description": "Text alignment"},
      {"name": "asChild", "type": "boolean", "default": "false", "description": "Radix Slot pattern"}
    ],
    "example": "<Heading level={1} size=\"3xl\">Page Title</Heading>\n<Heading level={2} align=\"center\" weight=\"semibold\">Section</Heading>"
  },
  {
    "name": "Input",
    "slug": "input",
