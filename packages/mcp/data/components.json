  {
    "name": "Dialog",
    "slug": "dialog",
    "description": "Accessible modal dialog with overlay, built on Radix UI",
    "category": "overlay",
    "imports": ["Dialog", "DialogTrigger", "DialogContent", "DialogHeader", "DialogFooter", "DialogTitle", "DialogDescription", "DialogClose"],
    "props": [
